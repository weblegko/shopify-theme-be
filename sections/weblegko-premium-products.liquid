<!-- sections/weblegko-premium-products.liquid -->

{%- style -%}
  /* Кастомная пагинация для премиум-слайдера */
  .premium-pagination {
    display: flex !important;
    justify-content: center !important;
    gap: 0.8rem;
    margin-top: 3rem;
  }

  .premium-pagination .swiper-pagination-bullet {
    width: 4rem !important;
    height: 0.2rem !important;
    border-radius: 0 !important;
    background: rgba(0, 0, 0, 0.2) !important;
    opacity: 1 !important;
    transition: all 0.3s ease;
  }

  .premium-pagination .swiper-pagination-bullet-active {
    background: #1a1a1a !important;
  }

  /* ---------- НОВОЕ: одинаковые слайды по высоте ---------- */ 
{%- endstyle -%}

<section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
  <div class="tw:max-w-[112rem] tw:mx-auto tw:py-[5rem] tw:lg:py-[12.8rem]">
    <!-- Заголовок -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[3rem]">
        <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.33] tw:lg:leading-[1.2] tw:text-center">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
            <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:text-center">
              {{ section.settings.description }}
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Слайдер -->
    <div class="swiper premiumSwiper tw:relative tw:!overflow-visible tw:sm:!overflow-hidden">
      <div class="swiper-wrapper">
        {%- if section.settings.collection != blank -%}
          {%- for product in section.settings.collection.products -%}
            {%- assign variant = product.selected_or_first_available_variant -%}
            {%- assign product_form_id = 'quick-add-' | append: section.id | append: '-' | append: product.id -%}
            {%- assign qty_rules = false -%}
            {%- if variant.quantity_rule.min > 1
              or variant.quantity_rule.max != null
              or variant.quantity_rule.increment > 1
            -%}
              {%- assign qty_rules = true -%}
            {%- endif -%}

            <div class="swiper-slide tw:h-auto">
              <div
                class="tw:h-full tw:flex tw:flex-col tw:group tw:px-[0.8rem] tw:pt-[0.8rem] tw:pb-[1.6rem] tw:rounded-[1.6rem] tw:bg-white tw:overflow-hidden"
                data-product-id="{{ product.id }}"
                data-variant-id="{{ variant.id }}"
              >
                <!-- Картинка -->
                <a
                  href="{{ product.url }}"
                  class="tw:block tw:aspect-square tw:overflow-hidden tw:rounded-[0.8rem] tw:mb-[1.6rem] tw:bg-[#f2f1ed]"
                >
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="tw:w-full tw:h-full tw:object-cover tw:transition-transform tw:duration-300 group-hover:tw:scale-105"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {%- else -%}
                    <div class="tw:w-full tw:h-full tw:flex tw:items-center tw:justify-center">
                      {{ 'product-1' | placeholder_svg_tag: 'tw:w-[6rem] tw:h-[6rem] tw:text-[#d4d4d4]' }}
                    </div>
                  {%- endif -%}
                </a>

                <!-- Информация -->
                <div class="tw:px-[1rem] tw:flex tw:flex-col tw:flex-1">
                  <a href="{{ product.url }}">
                    <h3 class="tw:text-[1.8rem] tw:min-h-[3em] tw:font-medium tw:tracking-[-0.01em] tw:text-grayscale-950 tw:hover:text-black tw:leading-[1.33] tw:line-clamp-2 tw:whitespace-normal">
                      {{ product.title }}
                    </h3>
                  </a>

                  {%- if product.description != blank -%}
                    <p class="tw:mt-[0.6rem] tw:text-[1.2rem] tw:tracking-[-0.01em] tw:text-grayscale-600 tw:leading-[1.33] tw:line-clamp-2 tw:whitespace-normal">
                      {{ product.description | strip_html }}
                    </p>
                  {%- endif -%}

                  <div class="tw:w-full tw:h-[0.1rem] tw:bg-grayscale-50 tw:mt-[1.5rem] tw:mb-[1rem]">
                    <span></span>
                  </div>

                  <!-- Цены -->
                  <div class="tw:flex tw:flex-nowrap tw:gap-[0.8rem] tw:mt-[0.8rem] tw:mb-[1.4rem]">
                    {%- if product.compare_at_price > product.price -%}
                      {%- assign discount = product.compare_at_price | minus: product.price -%}
                      {%- assign discount_percentage = discount
                        | times: 100.0
                        | divided_by: product.compare_at_price
                        | round
                      -%}
                      <span class="tw:text-[2.4rem] tw:font-medium tw:whitespace-nowrap tw:text-grayscale-950 tw:leading-[1.33] tw:tracking-[-0.01em]">
                        <span>From</span>
                        <span class="tw:text-additional-red">
                          {{ product.price | money }}
                        </span>
                      </span>
                      <span class="tw:text-[1.4rem] tw:text-grayscale-400 tw:leading-[1.43] tw:tracking-[-0.01em] tw:line-through tw:whitespace-nowrap">
                        {{ product.compare_at_price | money }}
                      </span>
                      <span class="tw:mt-1 tw:shrink-0 tw:px-[0.8rem] tw:h-[2.8rem] tw:bg-golden tw:text-[1.4rem] tw:text-grayscale-950 tw:leading-[1] tw:flex tw:items-center tw:justify-center tw:uppercase tw:rounded-full">
                        {{ discount_percentage }}% off
                      </span>
                    {%- else -%}
                      <span class="tw:text-[2.4rem] tw:font-medium tw:whitespace-nowrap tw:text-grayscale-950 tw:leading-[1.33] tw:tracking-[-0.01em]">                        
                        <span class="tw:text-grayscale-950">
                          {{ product.price | money }}
                        </span>
                      </span>
                    {%- endif -%}
                  </div>

                  <div class="tw:w-full tw:h-[0.1rem] tw:bg-grayscale-50 tw:mt-[0.5rem] tw:mb-[1.5rem]">
                    <span></span>
                  </div>

                  <!-- Статичные опции (оставлены без изменений) -->
                  <div class="tw:flex tw:flex-col tw:gap-3 tw:mb-[3rem]">
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >Only supplement targeting every aging hallmark</span
                      >
                    </div>
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >Restore cellular energy and activate autophagy</span
                      >
                    </div>
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >NSF Certified for Sport</span
                      >
                    </div>
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >90-day money-back guarantee</span
                      >
                    </div>
                  </div>

                  <!-- ===== БЛОК КНОПОК (как в popular-products) ===== -->
                  <div class="tw:mt-auto">
                    {%- if product.variants_count > 1 or qty_rules -%}
                      <modal-opener data-modal="#QuickAdd-{{ product.id }}">
                        <button
                          id="{{ product_form_id }}-submit"
                          type="submit"
                          name="add"
                          class="
                            tw:w-full tw:border-0 tw:flex tw:items-center tw:justify-center tw:rounded-full tw:transition-colors tw:duration-300
                            tw:pt-1 tw:px-[1.6rem] tw:h-[4rem] tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium
                            tw:bg-golden hover:tw:bg-goldendark tw:cursor-pointer
                          "
                          aria-haspopup="dialog"
                          aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                          data-product-url="{{ product.url }}"
                        >
                          {{ 'products.product.choose_options' | t }}
                          {%- render 'loading-spinner' -%}
                        </button>
                      </modal-opener>
                      <quick-add-modal id="QuickAdd-{{ product.id }}" class="quick-add-modal">
                        <div
                          role="dialog"
                          aria-label="{{ 'products.product.choose_product_options' | t: product_name: product.title | escape }}"
                          aria-modal="true"
                          class="quick-add-modal__content global-settings-popup"
                          tabindex="-1"
                        >
                          <button
                            id="ModalClose-{{ product.id }}"
                            type="button"
                            class="quick-add-modal__toggle"
                            aria-label="{{ 'accessibility.close' | t }}"
                          >
                            {{- 'icon-close.svg' | inline_asset_content -}}
                          </button>
                          <div id="QuickAddInfo-{{ product.id }}" class="quick-add-modal__content-info"></div>
                        </div>
                      </quick-add-modal>
                    {%- else -%}
                      <product-form data-section-id="{{ section.id }}">
                        {%- form 'product',
                          product,
                          id: product_form_id,
                          class: 'form',
                          novalidate: 'novalidate',
                          data-type: 'add-to-cart-form'
                        -%}
                          <input
                            type="hidden"
                            name="id"
                            value="{{ variant.id }}"
                            class="product-variant-id"
                            {% unless variant.available %}
                              disabled
                            {% endunless %}
                          >

                          <div class="tw:flex tw:flex-col tw:gap-[1rem] tw:items">
                            <a
                              href="{{ product.url }}"
                              class="tw:text-[1.4rem] tw:mx-auto tw:inline-block tw:leading-[1.43] tw:tracking-[-0.04em]"
                            >
                              <span> More Info</span>
                            </a>

                            <button
                              id="{{ product_form_id }}-submit"
                              type="submit"
                              name="add"
                              class="
                                tw:border-0 tw:flex tw:items-center tw:justify-center tw:rounded-full tw:transition-colors tw:duration-300
                                tw:pt-1 tw:px-[1.6rem] tw:h-[4rem] tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium
                                {% if variant.available %}
                                  tw:bg-golden hover:tw:bg-goldendark tw:cursor-pointer
                                {% else %}
                                  tw:bg-gray-400 tw:cursor-not-allowed tw:opacity-70
                                {% endif %}
                              "
                              aria-haspopup="dialog"
                              aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                              aria-live="polite"
                              data-sold-out-message="true"
                              {% unless variant.available %}
                                disabled
                              {% endunless %}
                            >
                              <span>
                                {%- if variant.available -%}
                                  GET STARTED
                                {%- else -%}
                                  {{ 'products.product.sold_out' | t }}
                                {%- endif -%}
                              </span>
                              <span class="sold-out-message hidden">
                                {{ 'products.product.sold_out' | t }}
                              </span>
                              {%- render 'loading-spinner' -%}
                            </button>
                          </div>
                        {%- endform -%}
                      </product-form>
                    {%- endif -%}
                  </div>
                  <!-- ===== КОНЕЦ БЛОКА КНОПОК ===== -->
                </div>
              </div>
            </div>
          {%- endfor -%}

        {%- else -%}
          <!-- Плейсхолдеры -->
          {%- for i in (1..3) -%}
            <div class="swiper-slide tw:h-auto">
              <div class="tw:block tw:px-[0.8rem] tw:pt-[0.8rem] tw:pb-[1.6rem] tw:rounded-[1.6rem] tw:bg-white tw:mx-[0.5rem]">
                <div class="tw:aspect-square tw:bg-[#f2f1ed] tw:rounded-[0.8rem] tw:flex tw:items-center tw:justify-center tw:mb-[1.6rem]">
                  {{ 'product-1' | placeholder_svg_tag: 'tw:w-[6rem] tw:h-[6rem] tw:text-[#d4d4d4]' }}
                </div>
                <div class="tw:px-[1rem]">
                  <div class="tw:h-[1.6rem] tw:w-[70%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[0.8rem]"></div>
                  <div class="tw:h-[1.2rem] tw:w-[100%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[0.4rem]"></div>
                  <div class="tw:h-[1.2rem] tw:w-[60%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[1.2rem]"></div>
                  <div class="tw:h-[1.4rem] tw:w-[40%] tw:bg-[#f2f1ed] tw:rounded-full"></div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- Пагинация -->
    <div class="premium-pagination"></div>
  </div>
</section>

<script>
  function initPremiumSlider() {
    if (typeof Swiper !== 'undefined') {
      const sliderEl = document.querySelector('.premiumSwiper');
      if (sliderEl && !sliderEl.classList.contains('swiper-initialized')) {
        new Swiper('.premiumSwiper', {
          slidesPerView: 1,
          spaceBetween: 10,
          loop: true,
          speed: 600,
          autoplay: {
            delay: 4000,
            disableOnInteraction: false,
          },
          pagination: {
            el: '.premium-pagination',
            clickable: true,
          },
          breakpoints: {
            0: {
              slidesPerView: 1.045,
              spaceBetween: 10,
            },
            640: {
              slidesPerView: 2,
              spaceBetween: 20,
            },
            1024: {
              slidesPerView: 3,
              spaceBetween: 20,
            },
          },
        });
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPremiumSlider);
  } else {
    initPremiumSlider();
  }

  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.querySelector('.premiumSwiper')) {
      initPremiumSlider();
    }
  });
</script>

{% schema %}
{
  "name": "WEBLEGKO PREMIUM",
  "tag": "section",
  "class": "section-premium-products",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Premium Products",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Premium supplements for your health",
      "label": "Description Badge"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO PREMIUM"
    }
  ]
}
{% endschema %}
