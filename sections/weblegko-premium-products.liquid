<!-- sections/weblegko-premium-products.liquid -->

{%- style -%}
  /* Кастомная пагинация для премиум-слайдера */
  .premium-pagination {
    display: flex !important;
    justify-content: center !important;
    gap: 0.8rem;
    margin-top: 3rem;
  }

  .premium-pagination .swiper-pagination-bullet {
    width: 4rem !important;
    height: 0.2rem !important;
    border-radius: 0 !important;
    background: rgba(0, 0, 0, 0.2) !important;
    opacity: 1 !important;
    transition: all 0.3s ease;
  }

  .premium-pagination .swiper-pagination-bullet-active {
    background: #1a1a1a !important; /* тёмно-серый/чёрный, как в примере белый на тёмном фоне */
  }
{%- endstyle -%}

<section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
  <div class="tw:max-w-[112rem] tw:mx-auto tw:py-[5rem] tw:lg:py-[12.8rem]">
    <!-- Заголовок секции -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[3rem]">
        <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.33] tw:lg:leading-[1.2] tw:text-center">
          {{ section.settings.heading }}
        </h2>

        {%- if section.settings.description != blank -%}
          <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
            <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:text-center">
              {{ section.settings.description }}
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Слайдер товаров -->
    <div class="swiper premiumSwiper tw:relative tw:!overflow-visible tw:sm:!overflow-hidden">
      <div class="swiper-wrapper">
        {%- if section.settings.collection != blank -%}
          <!-- Вывод реальных товаров (все из коллекции) -->
          {%- for product in section.settings.collection.products -%}
            <!-- Обертка слайда -->
            <div class="swiper-slide tw:h-auto">
              <!-- Карточка товара -->
              <div
                class="tw:h-full tw:flex tw:flex-col tw:group tw:px-[0.8rem] tw:pt-[0.8rem] tw:pb-[1.6rem] tw:rounded-[1.6rem] tw:bg-white tw:overflow-hidden"
              >
                <!-- Обертка картинки -->
                <a
                  href="{{ product.url }}"
                  class="tw:block tw:aspect-square tw:overflow-hidden tw:rounded-[0.8rem] tw:mb-[1.6rem] tw:bg-[#f2f1ed]"
                >
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="tw:w-full tw:h-full tw:object-cover tw:transition-transform tw:duration-300 group-hover:tw:scale-105"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {%- else -%}
                    <div class="tw:w-full tw:h-full tw:flex tw:items-center tw:justify-center">
                      {{ 'product-1' | placeholder_svg_tag: 'tw:w-[6rem] tw:h-[6rem] tw:text-[#d4d4d4]' }}
                    </div>
                  {%- endif -%}
                </a>

                <!-- Информация о товаре -->
                <div class="tw:px-[1rem] tw:flex tw:flex-col tw:flex-1">
                  <!-- Заголовок -->
                  <a href="{{ product.url }}">
                    <h3 class="tw:text-[1.8rem] tw:font-medium tw:tracking-[-0.01em] tw:text-grayscale-950 tw:hover:text-black tw:leading-[1.33]">
                      {{ product.title }}
                    </h3>
                  </a>

                  <!-- Описание -->
                  {%- if product.description != blank -%}
                    <p class="tw:mt-[0.6rem] tw:text-[1.2rem] tw:tracking-[-0.01em] tw:text-grayscale-600 tw:leading-[1.33] tw:line-clamp-2 tw:whitespace-normal">
                      {{ product.description | strip_html }}
                    </p>
                  {%- endif -%}

                  <div class="tw:w-full tw:h-[0.1rem] tw:bg-grayscale-50 tw:mt-[1.5rem] tw:mb-[1rem]"></div>

                  <!-- Ряд с ценами и скидкой -->
                  <div class="tw:flex tw:flex-nowrap tw:gap-[0.8rem] tw:mt-[0.8rem] tw:mb-[1.4rem]">
                    {%- if product.compare_at_price > product.price -%}
                      {%- assign discount = product.compare_at_price | minus: product.price -%}
                      {%- assign discount_percentage = discount
                        | times: 100.0
                        | divided_by: product.compare_at_price
                        | round
                      -%}

                      <span class="tw:text-[2.4rem] tw:font-medium tw:whitespace-nowrap tw:text-grayscale-950 tw:leading-[1.33] tw:tracking-[-0.01em]">
                        <span>From</span>
                        <span class="tw:text-additional-red">
                          {{ product.price | money }}
                        </span>
                      </span>
                      <span class="tw:text-[1.4rem] tw:text-grayscale-400 tw:leading-[1.43] tw:tracking-[-0.01em] tw:line-through tw:whitespace-nowrap">
                        {{ product.compare_at_price | money }}
                      </span>

                      <span class="tw:mt-1 tw:shrink-0 tw:px-[0.8rem] tw:h-[2.8rem] tw:bg-golden tw:text-[1.4rem] tw:text-grayscale-950 tw:leading-[1] tw:flex tw:items-center tw:justify-center tw:uppercase tw:rounded-full">
                        {{ discount_percentage }}% off
                      </span>
                    {%- else -%}
                      <span class="tw:text-[1.4rem] tw:font-bold tw:text-grayscale-950 tw:whitespace-nowrap">
                        {{ product.price | money }}
                      </span>
                    {%- endif -%}
                  </div>

                  <div class="tw:w-full tw:h-[0.1rem] tw:bg-grayscale-50 tw:mt-[0.5rem] tw:mb-[1.5rem]"></div>

                  <!-- Опции -->
                  <div class="tw:flex tw:flex-col tw:gap-3 tw:mb-[3rem]">
                    <!-- 1 -->
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >Only supplement targeting every aging hallmark</span
                      >
                    </div>
                    <!-- 2 -->
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >Restore cellular energy and activate autophagy</span
                      >
                    </div>
                    <!-- 3 -->
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >NSF Certified for Sport</span
                      >
                    </div>
                    <!-- 4 -->
                    <div class="tw:flex tw:items-center tw:gap-2 tw:px-[0.8rem] tw:min-h-[3.2rem] tw:rounded-full tw:border tw:border-grayscale-100">
                      <svg
                        class="tw:w-[1.6rem] tw:h-[1.6rem] tw:text-additional-green"
                        focusable="false"
                        aria-hidden="true"
                      >
                        <use href="#check"></use>
                      </svg>
                      <span class="tw:my-[0.6rem] tw:text-[1.2rem] tw:leading-[1.1] tw:tracking-[-0.04em]"
                        >90-day money-back guarantee</span
                      >
                    </div>
                  </div>

                  <!-- Кнопка -->
                  <div class="tw:mt-auto">
                    <form action="/cart/add" method="post">
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

                      <div class="tw:flex tw:flex-col tw:gap-[1rem] tw:items">
                        <a
                          href="{{ product.url }}"
                          class="tw:text-[1.4rem] tw:mx-auto tw:inline-block tw:leading-[1.43] tw:tracking-[-0.04em]"
                        >
                          <span> More Info</span>
                        </a>

                        <button
                          type="submit"
                          class="tw:border-0 tw:cursor-pointer tw:bg-golden tw:hover:bg-goldendark tw:flex tw:items-center tw:justify-center tw:rounded-full tw:transition-colors tw:duration-300 tw:pt-1 tw:px-[1.6rem] tw:h-[4rem] tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium"
                        >
                          GET STARTED
                        </button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}

        {%- else -%}
          <!-- Плейсхолдеры, если коллекция не выбрана -->
          {%- for i in (1..3) -%}
            <div class="swiper-slide tw:h-auto">
              <div class="tw-block tw:px-[0.8rem] tw:pt-[0.8rem] tw:pb-[1.6rem] tw:rounded-[1.6rem] tw:bg-white tw:mx-[0.5rem]">
                <div class="tw:aspect-square tw:bg-[#f2f1ed] tw:rounded-[0.8rem] tw:flex tw:items-center tw:justify-center tw:mb-[1.6rem]">
                  {{ 'product-1' | placeholder_svg_tag: 'tw:w-[6rem] tw:h-[6rem] tw:text-[#d4d4d4]' }}
                </div>
                <div class="tw:px-[1rem]">
                  <div class="tw:h-[1.6rem] tw:w-[70%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[0.8rem]"></div>
                  <div class="tw:h-[1.2rem] tw:w-[100%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[0.4rem]"></div>
                  <div class="tw:h-[1.2rem] tw:w-[60%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[1.2rem]"></div>
                  <div class="tw:h-[1.4rem] tw:w-[40%] tw:bg-[#f2f1ed] tw:rounded-full"></div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    <!-- Пагинация под слайдером -->
    <div class="premium-pagination"></div>
  </div>
</section>

<script>
  function initPremiumSlider() {
    if (typeof Swiper !== 'undefined') {
      const sliderEl = document.querySelector('.premiumSwiper');
      if (sliderEl && !sliderEl.classList.contains('swiper-initialized')) {
        new Swiper('.premiumSwiper', {
          slidesPerView: 1,
          spaceBetween: 10,
          loop: true,
          speed: 600,
          autoplay: {
            delay: 4000,
            disableOnInteraction: false,
          },
          pagination: {
            el: '.premium-pagination', // ← новый селектор
            clickable: true,
          },
          breakpoints: {
            0: {
              slidesPerView: 1.045,
              spaceBetween: 10,
            },
            640: {
              slidesPerView: 2,
              spaceBetween: 20,
            },
            1024: {
              slidesPerView: 3,
              spaceBetween: 20,
            },
          },
        });
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPremiumSlider);
  } else {
    initPremiumSlider();
  }

  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.querySelector('.premiumSwiper')) {
      initPremiumSlider();
    }
  });
</script>

{% schema %}
{
  "name": "WEBLEGKO PREMIUM",
  "tag": "section",
  "class": "section-premium-products",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Premium Products",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Premium supplements for your health",
      "label": "Description Badge"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO PREMIUM"
    }
  ]
}
{% endschema %}
