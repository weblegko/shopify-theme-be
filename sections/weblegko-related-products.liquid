{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ============================================ */
  /* CSS GRID С 4 БРЕЙКПОИНТАМИ */
  /* ============================================ */

  /* Базово: 1 колонка для мобильных */
  #product-grid {
    display: grid !important;
    grid-template-columns: repeat(1, 1fr) !important;
    gap: {{ section.settings.col_gap_mobile }}px;
    width: 100% !important;
  }

  #product-grid .grid__item {
    width: 100% !important;
    min-width: 0 !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    flex-direction: column !important;
  }

  /* Брейкпоинт 1: 576px - 991px (планшеты) — 2 колонки */
  @media screen and (min-width: 576px) and (max-width: 991px) {
    #product-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: {{ section.settings.col_gap_tablet }}px;
    }
  }

  /* Брейкпоинт 2: 992px - 1279px (маленькие десктопы) — 3 колонки */
  @media screen and (min-width: 992px) and (max-width: 1279px) {
    #product-grid {
      grid-template-columns: repeat(3, 1fr) !important;
      gap: {{ section.settings.col_gap_desktop }}px;
    }
     /* При 3 карточках скрываем 4-ю */
    #product-grid .grid__item:nth-child(4) {
      display: none !important;
    }
  }

  /* Брейкпоинт 3: 1280px - 1535px (средние десктопы) — 4 колонки */
  @media screen and (min-width: 1280px) {
    #product-grid {
      grid-template-columns: repeat(4, 1fr) !important;
      gap: {{ section.settings.col_gap_desktop }}px;
    }
      /* При 4 колонках показываем все */
    #product-grid .grid__item:nth-child(4) {
      display: flex !important;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <product-recommendations
    class="related-products page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.products_to_show }}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
  >
    {% if recommendations.performed and recommendations.products_count > 0 %}
      <h2 class="related-products__heading inline-richtext {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
      <ul
        id="product-grid"
        role="list"
        class="grid product-grid"
      >
        {% assign skip_card_product_styles = false %}
        {% for recommendation in recommendations.products %}
          <li class="grid__item">
            {% render 'card-product',
              card_product: recommendation,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: section.settings.image_shape,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              skip_styles: skip_card_product_styles,
              quick_add: section.settings.quick_add,
              section_id: section.id
            %}
          </li>
          {%- assign skip_card_product_styles = true -%}
        {% endfor %}
      </ul>
    {% endif %}
  </product-recommendations>
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

